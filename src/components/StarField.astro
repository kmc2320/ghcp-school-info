<canvas id="starfield" aria-hidden="true" class="fixed inset-0 -z-20 h-full w-full pointer-events-none"></canvas>

<script>
  type Star = {
    x: number;
    y: number;
    r: number;
    vx: number;
    vy: number;
    phase: number;
  };

  const canvas = document.getElementById('starfield');
  if (canvas instanceof HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const stars: Star[] = [];
      const STAR_COUNT = 140;
      let animationId = 0;

      const resize = (): void => {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.floor(window.innerWidth * dpr);
        canvas.height = Math.floor(window.innerHeight * dpr);
        canvas.style.width = `${window.innerWidth}px`;
        canvas.style.height = `${window.innerHeight}px`;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      const createStars = (): void => {
        stars.length = 0;
        for (let i = 0; i < STAR_COUNT; i += 1) {
          stars.push({
            x: Math.random() * window.innerWidth,
            y: Math.random() * window.innerHeight,
            r: 0.5 + Math.random() * 1.8,
            vx: -0.05 + Math.random() * 0.1,
            vy: -0.05 + Math.random() * 0.1,
            phase: Math.random() * Math.PI * 2,
          });
        }
      };

      const draw = (tick: number): void => {
        ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
        for (const star of stars) {
          star.x += star.vx;
          star.y += star.vy;
          if (star.x < 0) star.x = window.innerWidth;
          if (star.x > window.innerWidth) star.x = 0;
          if (star.y < 0) star.y = window.innerHeight;
          if (star.y > window.innerHeight) star.y = 0;

          const alpha = 0.35 + (Math.sin(tick * 0.001 + star.phase) + 1) * 0.25;
          ctx.beginPath();
          ctx.fillStyle = `rgba(255, 247, 194, ${alpha.toFixed(3)})`;
          ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
          ctx.fill();
        }
      };

      const loop = (tick: number): void => {
        draw(tick);
        animationId = window.requestAnimationFrame(loop);
      };

      resize();
      createStars();
      draw(0);
      if (!reduceMotion) {
        animationId = window.requestAnimationFrame(loop);
      }

      window.addEventListener('resize', () => {
        resize();
        createStars();
      });

      window.addEventListener('beforeunload', () => {
        if (animationId) {
          window.cancelAnimationFrame(animationId);
        }
      });
    }
  }
</script>
