---
import { faqs } from '../../content/sections';
---

<section id="faq" class="section-shell py-14 md:py-18">
  <h2 class="mb-8 font-orbitron text-2xl text-cyan-100 md:text-3xl">FAQ</h2>
  <div class="grid gap-4">
    {faqs.map((item) => (
      <details class="glass-card rounded-2xl p-5">
        <summary class="cursor-pointer list-none font-bold text-slate-100">{item.q}</summary>
        <p class="pt-3 leading-relaxed text-slate-200/90">{item.a}</p>
      </details>
    ))}
  </div>
</section>
