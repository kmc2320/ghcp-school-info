---
import { links } from '../../content/sections';
---

<section id="links" class="section-shell py-14 md:py-18">
  <h2 class="mb-8 font-orbitron text-2xl text-cyan-100 md:text-3xl">公式リンク</h2>
  <div class="grid gap-4 md:grid-cols-3">
    {links.map((item) => (
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        class="glass-card rounded-2xl p-5 transition hover:-translate-y-1 hover:border-cyan-200/60"
      >
        <h3 class="font-bold text-slate-100">{item.label}</h3>
        <p class="mt-2 break-all text-xs text-cyan-100/80">{item.href}</p>
      </a>
    ))}
  </div>
</section>
