---
import FloatingCard from '../FloatingCard.astro';
import { features } from '../../content/sections';
---

<section id="features" class="section-shell py-14 md:py-18">
  <h2 class="mb-8 font-orbitron text-2xl text-cyan-100 md:text-3xl">特色</h2>
  <div class="grid gap-5 md:grid-cols-3">
    {features.map((item) => (
      <FloatingCard title={item.title} body={item.body} />
    ))}
  </div>
</section>
