---
const navItems = [
  { href: '#about', label: '概要' },
  { href: '#features', label: '特色' },
  { href: '#curriculum', label: 'カリキュラム' },
  { href: '#life', label: '寮生活' },
  { href: '#admissions', label: '入試' },
  { href: '#faq', label: 'FAQ' },
  { href: '#links', label: 'リンク' },
];
---

<header class="sticky top-0 z-30 border-b border-white/10 bg-[#07031fcc]/85 backdrop-blur-lg">
  <nav class="section-shell flex flex-wrap items-center justify-between gap-3 py-4">
    <a href="#top" class="font-orbitron text-sm tracking-[0.2em] text-cyan-200">KAMIYAMA SPACE GUIDE</a>
    <ul class="flex flex-wrap items-center gap-3 text-xs text-slate-200 md:text-sm">
      {navItems.map((item) => (
        <li>
          <a class="rounded-full px-3 py-1 transition hover:bg-white/10" href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>
